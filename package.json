{
	"name": "n8n-nodes-bulkgate",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"version": "0.1.6",
	"description": "BulkGate integration for n8n",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Marek Piják",
		"email": "marekpijak@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/TOPefekt/n8n.git"
	},
	"bugs": {
		"url": "https://github.com/marekpijak/n8n-nodes-bulkgate/issues"
	},
	"homepage": "https://github.com/marekpijak/n8n-nodes-bulkgate#readme",
	"scripts": {
		"postinstall": "rm -rf node_modules/zod",
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "node scripts/dev.mjs",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/BulkGateApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Bulkgate/Bulkgate.node.js",
			"dist/nodes/BulkGateDeliveryReport/BulkGateDeliveryReport.node.js",
			"dist/nodes/BulkGateBulkDeliveryReport/BulkGateBulkDeliveryReport.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "^17.11.0",
		"typescript": "5.9.3",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
